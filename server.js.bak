const STATIC_EVENTS = [
  { title: "Wine Tasting Abend", location: "Ufer Weinbar", date: "Fr", time: "19:00", description: "Wein-Tasting mit wechselnden Weingütern — entspannt Leute kennenlernen", category: "tasting" },
