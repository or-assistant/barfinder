<!DOCTYPE html>
<html lang="de">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover, user-scalable=no">
<meta name="apple-mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
<meta name="theme-color" content="#0a0a0a">
<title>Barfinder Hamburg</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"/>
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
<style>
*,*::before,*::after{margin:0;padding:0;box-sizing:border-box}
:root{
--bg:#0a0a0a;--surface:#1a1a1a;--surface2:#252525;
--hot:#FF6B35;--hotGlow:rgba(255,107,53,.25);
--open:#34C759;--closed:#FF453A;
--blue:#0A84FF;--text:#f5f5f7;--text2:#86868B;--text3:#48484A;
--safe-top:env(safe-area-inset-top,0px);
--safe-bottom:env(safe-area-inset-bottom,0px);
--nav-h:64px;
--card-radius:16px;
}
html,body{height:100%;overflow:hidden;font-family:'Inter',system-ui,-apple-system,sans-serif;color:var(--text);background:var(--bg);-webkit-tap-highlight-color:transparent}
@keyframes pulse{0%,100%{opacity:1}50%{opacity:.5}}
@keyframes slideUp{from{opacity:0;transform:translateY(20px)}to{opacity:1;transform:none}}
@keyframes hotGlow{0%,100%{box-shadow:0 0 20px var(--hotGlow)}50%{box-shadow:0 0 40px var(--hotGlow)}}

/* SCROLL CONTAINER */
.feed{position:fixed;inset:0;overflow-y:auto;-webkit-overflow-scrolling:touch;padding:calc(var(--safe-top) + 16px) 16px calc(var(--nav-h) + var(--safe-bottom) + 24px);display:none;background:var(--bg)}
.feed.active{display:block}

/* HEADER */
.header{margin-bottom:20px}
.header-greeting{font-size:.82rem;color:var(--text2);font-weight:500;margin-bottom:2px}
.header-title{font-size:1.8rem;font-weight:900;letter-spacing:-.02em;line-height:1.1}
.header-title span{background:linear-gradient(135deg,#FF6B35,#FF3B30);-webkit-background-clip:text;-webkit-text-fill-color:transparent}

/* LOCATION TOGGLE */
.loc-toggle{display:flex;gap:8px;margin-bottom:20px;overflow-x:auto;scrollbar-width:none}
.loc-toggle::-webkit-scrollbar{display:none}
.loc-btn{flex-shrink:0;padding:8px 16px;border-radius:24px;font-size:.8rem;font-weight:600;border:1.5px solid var(--surface2);background:transparent;color:var(--text2);cursor:pointer;transition:all .2s;font-family:inherit}
.loc-btn.active{background:var(--text);color:var(--bg);border-color:var(--text)}
.loc-btn:active{transform:scale(.95)}

/* SECTION HEADERS */
.section{margin-bottom:24px;animation:slideUp .4s ease both}
.section:nth-child(2){animation-delay:.05s}
.section:nth-child(3){animation-delay:.1s}
.section:nth-child(4){animation-delay:.15s}
.section-head{display:flex;justify-content:space-between;align-items:center;margin-bottom:12px}
.section-title{font-size:1rem;font-weight:800;display:flex;align-items:center;gap:6px}
.section-more{font-size:.78rem;color:var(--blue);font-weight:600;background:none;border:none;cursor:pointer;font-family:inherit}

/* NOW PLAYING — Hero Hot Cards */
.hero-scroll{display:flex;gap:12px;overflow-x:auto;padding:2px 0 8px;scrollbar-width:none;margin:0 -16px;padding-left:16px;padding-right:16px}
.hero-scroll::-webkit-scrollbar{display:none}
.hero-card{flex:0 0 280px;background:var(--surface);border-radius:var(--card-radius);padding:16px;position:relative;overflow:hidden;cursor:pointer;transition:transform .15s}
.hero-card:active{transform:scale(.97)}
.hero-card.hot{animation:hotGlow 2s ease infinite;border:1px solid rgba(255,107,53,.3)}
.hero-card .hc-rank{position:absolute;top:12px;right:14px;font-size:2rem;font-weight:900;color:rgba(255,255,255,.06)}
.hero-card .hc-cat{font-size:.7rem;font-weight:700;color:var(--hot);text-transform:uppercase;letter-spacing:.5px;margin-bottom:6px}
.hero-card .hc-name{font-size:1.15rem;font-weight:800;margin-bottom:4px;line-height:1.2}
.hero-card .hc-addr{font-size:.75rem;color:var(--text2);margin-bottom:10px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.hero-card .hc-bottom{display:flex;justify-content:space-between;align-items:center}
.hero-card .hc-score{font-size:1.5rem;font-weight:900;color:var(--hot)}
.hero-card .hc-meta{display:flex;gap:8px;font-size:.72rem;color:var(--text2)}
.hero-card .hc-status{display:inline-flex;align-items:center;gap:4px;font-size:.7rem;font-weight:600;padding:3px 10px;border-radius:20px}
.hero-card .hc-status.open{background:rgba(52,199,89,.15);color:var(--open)}
.hero-card .hc-status.closed{background:rgba(255,69,58,.15);color:var(--closed)}

/* QUICK FILTERS — "Was willst du?" */
.quick-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:8px}
.quick-btn{display:flex;flex-direction:column;align-items:center;gap:4px;padding:14px 4px;background:var(--surface);border-radius:14px;border:none;cursor:pointer;transition:all .2s;font-family:inherit}
.quick-btn:active{transform:scale(.93);background:var(--surface2)}
.quick-btn .qb-icon{font-size:1.5rem}
.quick-btn .qb-label{font-size:.65rem;font-weight:600;color:var(--text2);text-align:center;line-height:1.2}
.quick-btn.active{background:var(--hot);border:none}
.quick-btn.active .qb-label{color:#fff}

/* VIBE HERO BUTTON */
.vibe-hero{width:100%;padding:18px 20px;border-radius:16px;border:none;cursor:pointer;font-family:inherit;background:linear-gradient(135deg,#7B2FBE,#E040FB,#FF6B35);background-size:200% 200%;animation:vibeShift 4s ease infinite;position:relative;overflow:hidden;transition:transform .15s,box-shadow .15s;box-shadow:0 4px 24px rgba(187,134,252,.3)}
.vibe-hero:active{transform:scale(.97)}
.vibe-hero.active{box-shadow:0 0 30px rgba(187,134,252,.5),0 0 60px rgba(224,64,251,.2);animation:vibeShift 2s ease infinite,vibePulse 1.5s ease infinite}
@keyframes vibeShift{0%,100%{background-position:0% 50%}50%{background-position:100% 50%}}
@keyframes vibePulse{0%,100%{box-shadow:0 0 30px rgba(187,134,252,.5)}50%{box-shadow:0 0 50px rgba(224,64,251,.4)}}
.vibe-hero .vh-title{font-size:1.15rem;font-weight:800;color:#fff;display:flex;align-items:center;gap:8px}
.vibe-hero .vh-sub{font-size:.75rem;font-weight:500;color:rgba(255,255,255,.75);margin-top:3px}

/* VIBE RECOMMENDATION OVERLAY */
.vibe-overlay{display:none;position:fixed;top:0;left:0;right:0;bottom:0;z-index:999;background:rgba(0,0,0,.85);backdrop-filter:blur(10px);overflow-y:auto;padding:20px}
.vibe-overlay.open{display:flex;flex-direction:column;align-items:center;animation:fadeIn .3s ease}
@keyframes fadeIn{from{opacity:0;transform:translateY(20px)}to{opacity:1;transform:translateY(0)}}
.vibe-overlay .vo-close{position:absolute;top:16px;right:20px;font-size:1.5rem;color:#fff;background:none;border:none;cursor:pointer;z-index:1001}
.vibe-overlay .vo-header{text-align:center;margin:40px 0 24px;width:100%;max-width:420px}
.vibe-overlay .vo-header h2{font-size:1.6rem;font-weight:900;background:linear-gradient(135deg,#BB86FC,#E040FB,#FF6B35);-webkit-background-clip:text;-webkit-text-fill-color:transparent;margin:0}
.vibe-overlay .vo-header p{color:rgba(255,255,255,.6);font-size:.85rem;margin-top:6px}
.vibe-reco{width:100%;max-width:420px;background:linear-gradient(135deg,rgba(123,47,190,.2),rgba(224,64,251,.1));border:1px solid rgba(187,134,252,.3);border-radius:16px;padding:20px;margin-bottom:16px;position:relative}
.vibe-reco.top{border-color:rgba(224,64,251,.5);background:linear-gradient(135deg,rgba(123,47,190,.3),rgba(224,64,251,.15));box-shadow:0 0 30px rgba(187,134,252,.2)}
.vibe-reco .vr-rank{position:absolute;top:-10px;left:16px;background:linear-gradient(135deg,#7B2FBE,#E040FB);color:#fff;font-weight:900;font-size:.85rem;padding:4px 12px;border-radius:20px}
.vibe-reco .vr-name{font-size:1.2rem;font-weight:800;color:#fff;margin:8px 0 4px}
.vibe-reco .vr-cat{font-size:.75rem;color:rgba(255,255,255,.5);margin-bottom:8px}
.vibe-reco .vr-reason{font-size:.9rem;color:rgba(255,255,255,.85);line-height:1.4;margin-bottom:12px}
.vibe-reco .vr-stats{display:flex;gap:12px;flex-wrap:wrap}
.vibe-reco .vr-stat{font-size:.75rem;color:rgba(255,255,255,.6);background:rgba(255,255,255,.08);padding:4px 10px;border-radius:8px}
.vibe-reco .vr-go{display:block;width:100%;margin-top:12px;padding:12px;border-radius:12px;border:none;cursor:pointer;font-family:inherit;font-size:.95rem;font-weight:700;color:#fff;background:linear-gradient(135deg,#7B2FBE,#E040FB);text-align:center;text-decoration:none}
.vibe-reco .vr-go:active{transform:scale(.98)}

/* METHODIK SECTION */
.methodik{background:var(--surface);border-radius:var(--card-radius);margin-top:24px;overflow:hidden}
.methodik-toggle{width:100%;display:flex;justify-content:space-between;align-items:center;padding:16px 18px;background:none;border:none;cursor:pointer;color:var(--text);font:700 .95rem/1.3 'Inter',sans-serif}
.methodik-toggle .mt-arrow{transition:transform .3s;font-size:.8rem;color:var(--text2)}
.methodik-toggle[aria-expanded="true"] .mt-arrow{transform:rotate(180deg)}
.methodik-body{max-height:0;overflow:hidden;transition:max-height .4s ease}
.methodik-body.open{max-height:3000px}
.methodik-inner{padding:0 18px 18px;font-size:.82rem;color:var(--text2);line-height:1.6}
.methodik-inner h4{color:var(--text);font-size:.88rem;font-weight:700;margin:16px 0 8px}
.methodik-inner h4:first-child{margin-top:0}
.methodik-inner ul{list-style:none;padding:0}
.methodik-inner li{padding:3px 0;display:flex;align-items:flex-start;gap:6px}
.methodik-inner li::before{content:'';display:inline-block;width:4px;height:4px;border-radius:50%;background:var(--text3);margin-top:8px;flex-shrink:0}
.weight-bar{display:inline-flex;align-items:center;gap:6px;margin-left:4px}
.weight-bar .wb-fill{height:6px;border-radius:3px;background:var(--hot)}
.weight-bar .wb-label{font-size:.7rem;color:var(--text3);font-weight:600}
.methodik-inner .data-sources{display:flex;flex-wrap:wrap;gap:6px;margin-top:8px}
.methodik-inner .ds-tag{font-size:.7rem;font-weight:600;padding:4px 10px;border-radius:8px;background:var(--surface2);color:var(--text2)}

/* TONIGHT FEED CARDS */
.tonight-card{background:var(--surface);border-radius:var(--card-radius);padding:14px;margin-bottom:10px;cursor:pointer;transition:transform .15s;border:1px solid transparent}
.tonight-card:active{transform:scale(.98)}
.tonight-card.is-hot{border-color:rgba(255,107,53,.2)}
.tc-top{display:flex;align-items:center;gap:12px}
.tc-icon{width:44px;height:44px;border-radius:12px;display:flex;align-items:center;justify-content:center;font-size:1.4rem;flex-shrink:0}
.tc-info{flex:1;min-width:0}
.tc-name{font-size:.92rem;font-weight:700;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.tc-sub{font-size:.75rem;color:var(--text2);margin-top:1px;display:flex;align-items:center;gap:6px}
.tc-score{font-size:.82rem;font-weight:800;color:var(--hot);flex-shrink:0}
.tc-tags{display:flex;gap:6px;margin-top:8px;flex-wrap:wrap}
.tc-tag{font-size:.65rem;font-weight:600;padding:3px 8px;border-radius:8px;background:var(--surface2);color:var(--text2)}
.tc-tag.open{background:rgba(52,199,89,.12);color:var(--open)}
.tc-tag.hot{background:rgba(255,107,53,.12);color:var(--hot)}
.tc-tag.event{background:rgba(10,132,255,.12);color:var(--blue)}

/* EVENT CARDS — Netzwerk */
.ev-feed-card{background:var(--surface);border-radius:var(--card-radius);padding:16px;margin-bottom:10px;border-left:3px solid var(--blue);cursor:pointer;transition:transform .15s}
.ev-feed-card:active{transform:scale(.98)}
.ev-feed-card.high-potential{border-left-color:var(--hot)}
.efc-time{font-size:.7rem;font-weight:700;color:var(--blue);text-transform:uppercase;letter-spacing:.3px;margin-bottom:4px}
.ev-feed-card.high-potential .efc-time{color:var(--hot)}
.efc-title{font-size:.95rem;font-weight:700;margin-bottom:4px;line-height:1.3}
.efc-location{font-size:.78rem;color:var(--text2);margin-bottom:8px;display:flex;align-items:center;gap:4px}
.efc-bottom{display:flex;justify-content:space-between;align-items:center}
.efc-tags{display:flex;gap:6px;flex-wrap:wrap;flex:1}
.efc-potential{font-size:.75rem;font-weight:700;padding:3px 10px;border-radius:20px;white-space:nowrap}

/* MAP TAB */
#mapTab{position:fixed;inset:0;z-index:0;display:none}
#mapTab.active{display:block}
#map{width:100%;height:100%}
.leaflet-control-zoom{display:none}

/* MAP OVERLAY — search + chips */
.map-search{position:fixed;top:calc(12px + var(--safe-top));left:12px;right:12px;z-index:500;display:none}
#mapTab.active ~ .map-search{display:block}
.search-bar{display:flex;align-items:center;gap:10px;background:rgba(26,26,26,.85);backdrop-filter:blur(20px) saturate(180%);-webkit-backdrop-filter:blur(20px) saturate(180%);border-radius:14px;padding:10px 16px;box-shadow:0 2px 16px rgba(0,0,0,.3)}
.search-bar svg{flex-shrink:0;color:var(--text2)}
.search-bar input{flex:1;border:none;background:none;font:400 .95rem/1.2 'Inter',sans-serif;color:var(--text);outline:none}
.search-bar input::placeholder{color:var(--text2)}

.map-chips{position:fixed;top:calc(60px + var(--safe-top));left:12px;right:12px;z-index:500;display:none;gap:8px;overflow-x:auto;scrollbar-width:none}
#mapTab.active ~ .map-chips{display:flex}
.map-chips::-webkit-scrollbar{display:none}
.map-chip{flex-shrink:0;padding:7px 14px;border-radius:20px;font-size:.78rem;font-weight:600;background:rgba(26,26,26,.85);backdrop-filter:blur(16px);color:var(--text2);border:none;cursor:pointer;font-family:inherit;transition:all .2s}
.map-chip.active{background:var(--text);color:var(--bg)}
.map-chip:active{transform:scale(.95)}

/* MAP LIST SHEET */
.map-sheet{position:fixed;left:0;right:0;bottom:0;z-index:700;background:var(--surface);border-radius:16px 16px 0 0;box-shadow:0 -4px 30px rgba(0,0,0,.3);transform:translateY(calc(100% - 160px - var(--nav-h)));transition:transform .35s cubic-bezier(.32,.72,0,1);will-change:transform;padding-bottom:calc(var(--nav-h) + var(--safe-bottom));max-height:calc(100vh - 60px);display:flex;flex-direction:column}
.map-sheet.mid{transform:translateY(calc(100% - 55vh - var(--nav-h)))}
.map-sheet.full{transform:translateY(0);border-radius:0}
.map-sheet.dragging{transition:none}
.sheet-handle{display:flex;justify-content:center;padding:10px 0 6px;flex-shrink:0;cursor:grab}
.sheet-handle span{width:36px;height:5px;background:var(--text3);border-radius:3px}
.map-sheet-scroll{flex:1;overflow-y:auto;-webkit-overflow-scrolling:touch;padding:0 16px 16px}

/* DETAIL SHEET */
.detail-sheet{position:fixed;left:0;right:0;bottom:0;z-index:900;background:var(--surface);border-radius:16px 16px 0 0;box-shadow:0 -4px 30px rgba(0,0,0,.4);transform:translateY(100%);transition:transform .4s cubic-bezier(.32,.72,0,1);max-height:90vh;display:flex;flex-direction:column;padding-bottom:calc(var(--safe-bottom) + 16px)}
.detail-sheet.open{transform:translateY(0)}
.detail-scroll{flex:1;overflow-y:auto;padding:0 20px 20px}
.det-name{font-size:1.4rem;font-weight:900;margin-bottom:4px}
.det-addr{color:var(--text2);font-size:.85rem;margin-bottom:16px}
.det-score-ring{width:100px;height:100px;border-radius:50%;display:flex;flex-direction:column;align-items:center;justify-content:center;margin:0 auto 16px;font-size:1.5rem;font-weight:800;line-height:1.1}
.det-score-ring .ring-emoji{font-size:1.2rem;margin-bottom:2px}
.det-score-ring .ring-val{font-size:1.4rem;font-weight:900}
.det-actions{display:flex;gap:10px;margin:16px 0}
.det-actions a{flex:1;padding:14px;border-radius:12px;text-align:center;text-decoration:none;font-weight:700;font-size:.9rem;color:#fff}
.det-actions .da-route{background:linear-gradient(135deg,#0A84FF,#007AFF)}
.det-actions .da-web{background:linear-gradient(135deg,#7B2FBE,#BB86FC)}
.det-actions .da-search{background:linear-gradient(135deg,#FF9500,#FF6B35)}
.det-section{margin-bottom:16px}
.det-section h3{font-size:.82rem;font-weight:700;color:var(--text2);text-transform:uppercase;letter-spacing:.5px;margin-bottom:8px}
.det-link{display:inline-flex;align-items:center;gap:6px;padding:10px 18px;border-radius:12px;background:var(--blue);color:#fff;text-decoration:none;font-weight:600;font-size:.85rem;margin-right:8px;margin-bottom:8px}
.det-link.secondary{background:var(--surface2);color:var(--blue)}

/* PEAK HOURS */
.peak-bar-wrap{margin:8px 0 4px}
.peak-bar{display:flex;gap:1px;height:28px;border-radius:8px;overflow:hidden}
.peak-bar .pb-cell{flex:1;display:flex;align-items:flex-end;justify-content:center;transition:all .2s}
.peak-hours-labels{display:flex;gap:1px;margin-top:2px}
.peak-hours-labels .phl{flex:1;text-align:center;font-size:.55rem;color:var(--text2)}
.week-cal{display:flex;flex-direction:column;gap:4px}
.week-cal .wc-row{display:flex;align-items:center;gap:8px;padding:6px 10px;border-radius:10px;font-size:.82rem}
.week-cal .wc-row.today{background:rgba(255,107,53,.1);font-weight:700}
.week-cal .wc-day{width:28px;font-weight:700;flex-shrink:0}
.week-cal .wc-icon{width:20px;flex-shrink:0}
.week-cal .wc-time{color:var(--text2);flex:1}

/* BOTTOM NAV */
.bottom-nav{position:fixed;left:0;right:0;bottom:0;z-index:800;display:flex;justify-content:space-around;align-items:center;height:var(--nav-h);padding-bottom:var(--safe-bottom);background:rgba(10,10,10,.85);backdrop-filter:blur(20px) saturate(180%);-webkit-backdrop-filter:blur(20px) saturate(180%);border-top:1px solid rgba(255,255,255,.06)}
.nav-btn{display:flex;flex-direction:column;align-items:center;gap:2px;background:none;border:none;cursor:pointer;padding:6px 20px;color:var(--text3);transition:color .2s;font-family:inherit}
.nav-btn.active{color:var(--text)}
.nav-btn .nav-icon{font-size:1.3rem}
.nav-btn .nav-label{font-size:.62rem;font-weight:600}

/* FAVORITES */
.fav-btn{position:absolute;top:10px;right:10px;font-size:1.3rem;cursor:pointer;z-index:10;filter:drop-shadow(0 1px 3px rgba(0,0,0,.5));transition:transform .15s}
.fav-btn:active{transform:scale(1.3)}
.fav-section{animation:slideUp .4s ease both}
.fav-scroll{display:flex;gap:12px;overflow-x:auto;padding:2px 0 8px;scrollbar-width:none;margin:0 -16px;padding-left:16px;padding-right:16px}
.fav-scroll::-webkit-scrollbar{display:none}
.fav-card{flex:0 0 200px;background:var(--surface);border-radius:var(--card-radius);padding:14px;position:relative;cursor:pointer;transition:transform .15s;border:1px solid rgba(187,134,252,.2)}
.fav-card:active{transform:scale(.97)}
.fav-card .fc-name{font-size:.92rem;font-weight:800;margin-bottom:3px;padding-right:28px}
.fav-card .fc-cat{font-size:.7rem;color:var(--text2);margin-bottom:8px}
.fav-card .fc-bottom{display:flex;justify-content:space-between;align-items:center}
.fav-card .fc-vibe{font-size:.85rem;font-weight:800;color:#BB86FC}
.fav-card .fc-status{font-size:.68rem;font-weight:600;padding:2px 8px;border-radius:12px}
.fav-card .fc-status.open{background:rgba(52,199,89,.15);color:var(--open)}
.fav-card .fc-status.closed{background:rgba(255,69,58,.15);color:var(--closed)}
.fav-refresh{background:none;border:none;font-size:1.1rem;cursor:pointer;padding:4px 8px;border-radius:8px;transition:all .2s}
.fav-refresh:active{transform:rotate(180deg)}

.empty-msg{text-align:center;color:var(--text2);padding:40px 0;font-size:.9rem}
.badge{font-size:.68rem;font-weight:600;padding:3px 8px;border-radius:8px;background:var(--surface2);color:var(--text2)}

/* Loading skeleton */
.skeleton{background:linear-gradient(90deg,var(--surface) 25%,var(--surface2) 50%,var(--surface) 75%);background-size:200% 100%;animation:shimmer 1.5s infinite;border-radius:var(--card-radius);height:80px;margin-bottom:10px}
@keyframes shimmer{0%{background-position:200% 0}100%{background-position:-200% 0}}
</style>
</head>
<body>

<!-- ═══ HEUTE FEED ═══ -->
<div class="feed active" id="feedHeute">
  <div class="header">
    <div class="header-greeting" id="greeting"></div>
    <div class="header-title" id="headerTitle"></div>
  </div>

  <div id="weatherBanner" style="display:none;padding:10px 14px;border-radius:12px;background:var(--surface);margin-bottom:12px;font-size:.82rem;font-weight:600;display:flex;align-items:center;gap:8px;color:var(--text2)"></div>
  <div id="eventBanner" style="display:none;padding:12px 14px;border-radius:12px;background:linear-gradient(135deg,rgba(255,107,53,.15),rgba(255,59,48,.15));margin-bottom:12px;font-size:.85rem;font-weight:700;color:var(--hot);display:flex;align-items:center;gap:8px"></div>
  <div class="loc-toggle" id="locToggle">
    <button class="loc-btn active" data-loc="home" onclick="setLocation('home')">🏠 Zuhause</button>
    <button class="loc-btn" data-loc="gps" onclick="setLocation('gps')">📍 Standort</button>
    <button class="loc-btn" data-loc="parents" onclick="setLocation('parents')">👨‍👩‍👦 Lentföhrden</button>
    <button class="loc-btn" data-loc="ostsee" onclick="setLocation('ostsee')">🏖️ Ostsee</button>
  </div>

  <div id="favSection"></div>
  <div id="heroSection" class="section"></div>
  <div id="dayPicker" class="section" style="display:flex;gap:8px;overflow-x:auto;scrollbar-width:none;margin-bottom:16px"></div>

  <!-- VIBE HERO BUTTON -->
  <div class="section" style="margin-bottom:16px">
    <button class="vibe-hero" id="vibeHeroBtn" onclick="showVibeRecommendation()">
      <div class="vh-title">🎉 Wo treffst du Leute?</div>
      <div class="vh-sub">Tippe für deine persönliche Empfehlung — jetzt!</div>
    </button>
  </div>

  <!-- VIBE RECOMMENDATION OVERLAY -->
  <div class="vibe-overlay" id="vibeOverlay">
    <button class="vo-close" onclick="closeVibeOverlay()">✕</button>
    <div class="vo-header">
      <h2>🎉 Hier solltest du JETZT hin!</h2>
      <p id="vibeOverlayTime"></p>
    </div>
    <div id="vibeRecoList"></div>
  </div>

  <div id="quickSection" class="section"></div>
  <div id="tonightSection" class="section"></div>
  <div id="eventsSection" class="section"></div>

  <!-- METHODIK -->
  <div class="methodik" id="methodik">
    <button class="methodik-toggle" aria-expanded="false" onclick="toggleMethodik()">
      <span>📊 Wie wir bewerten</span>
      <span class="mt-arrow">▼</span>
    </button>
    <div class="methodik-body" id="methodik-body">
      <div class="methodik-inner">
        <h4>🔥 HotScore (0–100)</h4>
        <p>Wie beliebt ist der Laden insgesamt?</p>
        <ul>
          <li>Google Rating <span class="weight-bar"><span class="wb-fill" style="width:40px"></span><span class="wb-label">40%</span></span></li>
          <li>Popularität (Reviews) <span class="weight-bar"><span class="wb-fill" style="width:30px"></span><span class="wb-label">30%</span></span></li>
          <li>Kategorie-Beliebtheit <span class="weight-bar"><span class="wb-fill" style="width:30px"></span><span class="wb-label">30%</span></span></li>
        </ul>

        <h4>🎉 VibeScore (0–100) — "Wo triffst du Leute?"</h4>
        <p>Wahrscheinlichkeit, auf Leute zu treffen & gute Stimmung.</p>
        <ul>
          <li>Kategorie-Basis: Cocktailbar/Weinbar hoch, Café niedrig</li>
          <li>Zeitfaktor: Abends höher als tagsüber</li>
          <li>Wochenend-Boost: Fr/Sa +30%</li>
          <li>Event-Boost: Wenn Event stattfindet +20</li>
          <li>Google Rating: 4.5+ → +10, 4.0+ → +5</li>
          <li>Keywords: "live musik", "after work" etc.</li>
          <li>Smoker-Bonus: Stammkneipe-Effekt +5</li>
        </ul>

        <h4>📊 Geschätzte Auslastung (0–100)</h4>
        <p>Wie voll ist es gerade wahrscheinlich?</p>
        <ul>
          <li>Öffnungszeiten-basiert</li>
          <li>Peak-Zeiten je Kategorie (Cocktailbar: 22–01h, Pub: 20–23h)</li>
          <li>Wochentag-Multiplikator (Fr/Sa ×1.3, So–Di ×0.75)</li>
          <li>Wetter: Regen → weniger draußen, mehr drinnen</li>
          <li>Großevents: Hafengeburtstag, OMR → Stadt-Boost</li>
          <li>Google Rating Boost</li>
        </ul>

        <h4>🌤️ Wetter-Einfluss</h4>
        <ul>
          <li>Starker Regen → Outdoor ×0.5, Indoor ×1.1</li>
          <li>Schönes Wetter 20°C+ → Biergarten ×1.2</li>
          <li>Kalt &lt;0°C → Alle ×0.8</li>
        </ul>

        <h4>📡 Datenquellen</h4>
        <div class="data-sources">
          <span class="ds-tag">🗺️ OpenStreetMap (800+)</span>
          <span class="ds-tag">⭐ Google Ratings (104)</span>
          <span class="ds-tag">🎉 Luma Events</span>
          <span class="ds-tag">👥 Meetup.com</span>
          <span class="ds-tag">🎫 Eventbrite</span>
          <span class="ds-tag">📰 Abendblatt RSS</span>
          <span class="ds-tag">🏙️ hamburg-tourism.de</span>
          <span class="ds-tag">🤖 ARIC Hamburg</span>
          <span class="ds-tag">📺 nextMedia.Hamburg</span>
          <span class="ds-tag">🎨 Kreativ Gesellschaft</span>
          <span class="ds-tag">🌤️ Open-Meteo</span>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- ═══ MAP TAB ═══ -->
<div id="mapTab">
  <div id="map"></div>
</div>
<div class="map-search" id="mapSearch">
  <div class="search-bar">
    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><circle cx="11" cy="11" r="7"/><path d="m21 21-4.35-4.35"/></svg>
    <input type="text" id="searchInput" placeholder="Bar, Club oder Adresse…">
  </div>
</div>
<div class="map-chips" id="mapChips"></div>
<div class="map-sheet" id="mapSheet" style="display:none">
  <div class="sheet-handle" id="sheetHandle"><span></span></div>
  <div class="map-sheet-scroll" id="mapSheetScroll"></div>
</div>

<!-- ═══ EVENTS TAB ═══ -->
<div class="feed" id="feedEvents">
  <div class="header">
    <div class="header-greeting">Netzwerk & Events</div>
    <div class="header-title">Was <span>läuft</span> diese Woche?</div>
  </div>
  <div id="eventTimeFilter" style="display:flex;gap:8px;margin-bottom:12px;overflow-x:auto;scrollbar-width:none">
    <button class="loc-btn" onclick="setEventTime('all')">Alle</button>
    <button class="loc-btn" onclick="setEventTime('today')">Heute</button>
    <button class="loc-btn" onclick="setEventTime('tomorrow')">Morgen</button>
    <button class="loc-btn active" onclick="setEventTime('week')">Diese Woche</button>
    <button class="loc-btn" onclick="setEventTime('later')">Später</button>
  </div>
  <div id="vibeFilters" style="display:flex;flex-wrap:wrap;gap:8px;margin-bottom:20px"></div>
  <div id="eventsFeed"></div>
</div>

<div class="feed" id="feedSources">
  <div class="header">
    <div class="header-greeting">Daten-Pipeline</div>
    <div class="header-title">📡 <span>Quellen</span> & Status</div>
  </div>
  <div id="sourcesList" style="display:flex;flex-direction:column;gap:12px"></div>
</div>

<!-- ═══ DETAIL ═══ -->
<div class="detail-sheet" id="detailSheet">
  <div class="sheet-handle" id="detailClose"><span></span></div>
  <div class="detail-scroll" id="detailScroll"></div>
</div>

<!-- ═══ NAV ═══ -->
<nav class="bottom-nav">
  <button class="nav-btn active" data-tab="heute"><span class="nav-icon">⚡</span><span class="nav-label">Heute</span></button>
  <button class="nav-btn" data-tab="map"><span class="nav-icon">🗺️</span><span class="nav-label">Karte</span></button>
  <button class="nav-btn" data-tab="events"><span class="nav-icon">🤝</span><span class="nav-label">Events</span></button>
  <button class="nav-btn" data-tab="sources"><span class="nav-icon">📡</span><span class="nav-label">Quellen</span></button>
</nav>

<script>
// ═══ CONFIG ═══
const SAVED_LOCS={
  home:{lat:53.5775,lon:9.9785,label:'Zuhause',radius:1000},
  parents:{lat:53.8760,lon:9.8864,label:'Lentföhrden',radius:20000},
  ostsee:{lat:54.5078,lon:9.9704,label:'Ostseecamp Lehmberg',radius:15000},
};

// ═══ STATE ═══
const S={lat:53.5775,lon:9.9785,radius:1000,category:'',places:[],hot:[],markers:[],currentLoc:'home',filter:''};
let map,startMarker,radiusCircle,currentTab='heute',mapInited=false;

// ═══ FAVORITES ═══
function getFavorites(){try{return JSON.parse(localStorage.getItem('barfinder_favorites')||'[]')}catch{return[]}}
function saveFavorites(favs){localStorage.setItem('barfinder_favorites',JSON.stringify(favs))}
function isFavorite(name){return getFavorites().includes((name||'').toLowerCase())}
function toggleFavorite(name){
  const key=(name||'').toLowerCase();let favs=getFavorites();
  const adding=!favs.includes(key);
  if(adding)favs.push(key);else favs=favs.filter(f=>f!==key);
  saveFavorites(favs);renderFavorites();renderHero();renderTonightFeed();
  // Live-refresh Google Rating when adding a favorite
  if(adding){
    fetch('/api/refresh-place?name='+encodeURIComponent(name)).then(r=>r.json()).then(d=>{
      if(d.ok&&d.rating&&d.rating.rating){
        // Update local place data
        const p=S.places.find(x=>(x.name||'').toLowerCase()===key);
        if(p){p.googleRating=d.rating.rating;p.googleReviews=d.rating.rating_n}
        renderFavorites();
      }
    }).catch(()=>{});
  }
}
function renderFavorites(){
  const el=document.getElementById('favSection');
  const favs=getFavorites();
  if(!favs.length||!S.places.length){el.innerHTML='';return}
  const favPlaces=favs.map(f=>S.places.find(p=>(p.name||'').toLowerCase()===f)).filter(Boolean);
  if(!favPlaces.length){el.innerHTML='';return}
  el.innerHTML=`<div class="section fav-section">
    <div class="section-head">
      <div class="section-title">⭐ Deine Favoriten</div>
      <button class="fav-refresh" onclick="loadAll()" title="Aktualisieren">🔄</button>
    </div>
    <div class="fav-scroll">${favPlaces.map(p=>{
      const isOpen=p.isOpen===true;
      return`<div class="fav-card" onclick="openDetail(findPlace('${esc(p.name)}'))">
        <span class="fav-btn" onclick="event.stopPropagation();toggleFavorite('${esc(p.name)}')">❤️</span>
        <div class="fc-name">${esc(p.name)}</div>
        <div class="fc-cat">${getCatIcon(p.category)} ${getCatName(p.category)}</div>
        <div class="fc-bottom">
          <div class="fc-vibe">${p.vibeEmoji||'🎉'} ${p.vibeScore||0}%</div>
          <div class="fc-status ${isOpen?'open':'closed'}">${isOpen?'🟢 Offen':'🔴 Zu'}</div>
        </div>
        ${p.estimatedBusyness>10?`<div style="margin-top:6px;height:3px;border-radius:2px;background:var(--surface2);overflow:hidden"><div style="height:100%;width:${p.estimatedBusyness}%;background:${p.busynessColor||'#666'};border-radius:2px"></div></div>`:''}
      </div>`}).join('')}</div>
  </div>`;
}

// ═══ UTILS ═══
function esc(s){if(!s)return'';const d=document.createElement('div');d.textContent=s;return d.innerHTML}
async function api(path){try{const r=await fetch(path);return r.ok?r.json():null}catch{return null}}
function getBerlinTime(){return new Date(new Date().toLocaleString('en-US',{timeZone:'Europe/Berlin'}))}

function getCatIcon(c){
  const m={'pub':'🍺','cocktailbar':'🍸','bar':'🍹','wine':'🍷','irish-pub':'☘️','nightclub':'🪩','biergarten':'🍺','cafe':'☕','restaurant':'🍽️','brewery':'🍺','lounge':'🥂','sports_bar':'⚽'};
  return m[c]||'🍻';
}
function busynessIcon(v){return v>=80?'🔴':v>=60?'🟠':v>=40?'🟡':v>=20?'🟢':'⚪'}
function busynessBg(color){if(!color)return'var(--surface2)';const m={'#34C759':'rgba(52,199,89,.12)','#FFD60A':'rgba(255,214,10,.12)','#FF9500':'rgba(255,149,0,.12)','#FF453A':'rgba(255,69,58,.12)'};return m[color]||'var(--surface2)'}
function getCatName(c){
  const m={'pub':'Kneipe','cocktailbar':'Cocktailbar','bar':'Bar','wine':'Weinbar','irish-pub':'Irish Pub','nightclub':'Club','cafe':'Café','biergarten':'Biergarten','brewery':'Brauerei','lounge':'Lounge','sports_bar':'Sportsbar','restaurant':'Restaurant'};
  return m[c]||c||'Bar';
}

// ═══ GREETING ═══
function updateGreeting(){
  const h=getBerlinTime().getHours();
  const el=document.getElementById('greeting');
  const title=document.getElementById('headerTitle');
  if(h<12){el.textContent='Guten Morgen ☀️';title.innerHTML='Was ist heute <span>los</span>?'}
  else if(h<17){el.textContent='Moin 👋';title.innerHTML='Wo geht heute <span>was</span>?'}
  else if(h<21){el.textContent='Feierabend! 🍺';title.innerHTML='Wo gehst du <span>heute hin</span>?'}
  else{el.textContent='Nachtschicht 🌙';title.innerHTML='Was geht <span>jetzt noch</span>?'}
}

// ═══ LOCATION ═══
function setLocation(loc){
  document.querySelectorAll('.loc-btn').forEach(b=>b.classList.toggle('active',b.dataset.loc===loc));
  S.currentLoc=loc;
  if(loc==='gps'){
    if(!navigator.geolocation)return;
    // Show loading while GPS resolves
    document.getElementById('heroSection').innerHTML='<div style="text-align:center;padding:20px;color:var(--text2)">📍 Standort wird ermittelt...</div>';
    document.getElementById('tonightSection').innerHTML='<div class="skeleton"></div>';
    navigator.geolocation.getCurrentPosition(pos=>{
      S.lat=pos.coords.latitude;S.lon=pos.coords.longitude;
      // Smart radius: match saved location if nearby, else urban 3km / rural 20km
      const gLat=pos.coords.latitude, gLon=pos.coords.longitude;
      const nearSaved=Object.values(SAVED_LOCS).find(s=>{const d=Math.sqrt((gLat-s.lat)**2+(gLon-s.lon)**2)*111000;return d<s.radius});
      S.radius = nearSaved ? nearSaved.radius : ((gLat>53.4&&gLat<53.7&&gLon>9.7&&gLon<10.2) ? 3000 : 20000);
      loadAll();
    },()=>{
      // GPS failed — fall back to home
      document.getElementById('heroSection').innerHTML='<div style="text-align:center;padding:20px;color:var(--closed)">📍 GPS nicht verfügbar — zeige Zuhause</div>';
      setLocation('home');
    },{enableHighAccuracy:true,timeout:10000});
    return;
  }
  const sv=SAVED_LOCS[loc];
  if(sv){S.lat=sv.lat;S.lon=sv.lon;S.radius=sv.radius;loadAll()}
}

// ═══ LOAD ALL ═══
async function loadAll(){
  // Show skeletons
  document.getElementById('heroSection').innerHTML='<div class="skeleton"></div>';
  document.getElementById('tonightSection').innerHTML='<div class="skeleton"></div><div class="skeleton"></div><div class="skeleton"></div>';

  const[places,hot]=await Promise.all([
    api(`/api/places?lat=${S.lat}&lon=${S.lon}&radius=${S.radius}`),
    api(`/api/hot?lat=${S.lat}&lon=${S.lon}&radius=${S.radius}`)
  ]);
  S.places=(places&&places.places)?places.places:[];
  const hotList=(hot||[]).slice(0,10);
  if(hotList.length<3){
    S.hot=[...S.places].sort((a,b)=>(b.hotScore||0)-(a.hotScore||0)).slice(0,10);
  }else{S.hot=hotList}

  renderFavorites();
  renderDayPicker();
  renderHero();
  renderQuickFilters();
  renderTonightFeed();
  if(mapInited){updateMap()}
}

// ═══ HERO — Top Vibe Spots ═══
function renderHero(){
  const el=document.getElementById('heroSection');
  // Combine hot + all places, dedupe, open or opens today, sort by vibe
  const allOpen=[...S.hot,...S.places].filter(h=>h.isOpen===true||opensToday(h)!==false);
  const seen=new Set();const deduped=[];
  allOpen.forEach(h=>{const k=h.name?.toLowerCase();if(!seen.has(k)){seen.add(k);deduped.push(h)}});
  const topVibe=deduped.sort((a,b)=>(b.vibeScore||0)-(a.vibeScore||0)).slice(0,5);

  if(!topVibe.length||topVibe[0].vibeScore<10){
    el.innerHTML=`<div class="section-head"><div class="section-title">😴 Gerade ruhig</div></div>
    <div style="padding:20px;text-align:center;color:var(--text2);font-size:.85rem">Wenig los in der Nähe. Probier einen größeren Radius.</div>`;
    return;
  }
  el.innerHTML=`
  <div class="section-head"><div class="section-title">🎉 Hier triffst du Leute</div></div>
  <div class="hero-scroll">${topVibe.map((h,i)=>{
    const vibe=h.vibeScore||0;const hot=h.hotScore||0;const isVibe=vibe>50;
    const isFav=isFavorite(h.name);
    return`<div class="hero-card${isVibe?' hot':''}" onclick="openDetail(findPlace('${esc(h.name)}')}">
      <span class="fav-btn" onclick="event.stopPropagation();toggleFavorite('${esc(h.name)}')">${isFav?'❤️':'🤍'}</span>
      <div class="hc-rank">${i+1}</div>
      <div class="hc-cat">${getCatIcon(h.category)} ${getCatName(h.category)}</div>
      <div class="hc-name">${esc(h.name)}</div>
      <div class="hc-addr">${esc(h.address||h.street||'')}</div>
      <div class="hc-bottom">
        <div class="hc-score" style="color:#BB86FC">${h.vibeEmoji||'🎉'} ${vibe}%</div>
        <div style="display:flex;gap:8px;align-items:center">
          ${hot>0?`<span style="font-size:.7rem;font-weight:600;color:var(--hot)">🔥${hot}%</span>`:''}
          <div class="hc-status open">🟢 Offen</div>
        </div>
      </div>
      ${h.googleRating?`<div style="margin-top:6px;font-size:.72rem;font-weight:600;color:#FFC107">⭐ ${h.googleRating}${h.googleReviews?' ('+h.googleReviews+')':''}</div>`:''}
      ${h.estimatedBusyness>0?`<div style="margin-top:4px;display:flex;align-items:center;gap:6px"><div style="flex:1;height:4px;border-radius:2px;background:var(--surface2);overflow:hidden"><div style="height:100%;width:${h.estimatedBusyness}%;background:${h.busynessColor||'#666'};border-radius:2px"></div></div><span style="font-size:.65rem;font-weight:600;color:${h.busynessColor||'var(--text2)'}">${busynessIcon(h.estimatedBusyness)} ${h.busynessLabel||''}</span></div>`:''}
      <div style="margin-top:4px;font-size:.72rem;font-weight:600;color:${vibe>=55?'#BB86FC':'var(--text2)'}">${h.vibeLabel||''}</div>
    </div>`;
  }).join('')}</div>`;
}

// ═══ DAY PICKER ═══
let selectedDay=0; // 0=heute, 1=morgen, etc.

function renderDayPicker(){
  const el=document.getElementById('dayPicker');
  const days=[];
  for(let i=0;i<7;i++){
    const d=new Date(getBerlinTime());d.setDate(d.getDate()+i);
    const label=i===0?'Heute':i===1?'Morgen':d.toLocaleDateString('de-DE',{weekday:'short',day:'numeric'});
    days.push({i,label});
  }
  el.innerHTML=days.map(d=>`<button class="loc-btn${selectedDay===d.i?' active':''}" onclick="pickDay(${d.i})" style="flex-shrink:0">${d.label}</button>`).join('');
}

function pickDay(i){
  selectedDay=i;
  renderDayPicker();
  renderHero();
  renderTonightFeed();
}

// Check if place opens on the selected day
function opensToday(p){
  const oh=p.opening_hours||p.openingHours||'';
  if(!oh)return null; // unknown = might be open
  if(oh==='24/7')return true;
  
  // For today (selectedDay=0) and place is currently open
  if(selectedDay===0&&(p.isOpen===true))return true;
  
  const berlinNow=getBerlinTime();
  const target=new Date(berlinNow);target.setDate(target.getDate()+selectedDay);
  const dowNames=['Su','Mo','Tu','We','Th','Fr','Sa'];
  const targetDow=dowNames[target.getDay()];
  
  // Check day ranges in opening hours
  // Common patterns: "Mo-Fr", "Mo-Sa", "Mo-Su", "Tu-Sa", "Fr,Sa", "Fr 18:00-03:00"
  const dayOrder={'Mo':1,'Tu':2,'We':3,'Th':4,'Fr':5,'Sa':6,'Su':0};
  const targetNum=dayOrder[targetDow];
  if(targetNum===undefined)return null;
  
  // Check explicit day mention
  if(oh.includes(targetDow))return true;
  
  // Check day ranges like "Mo-Fr", "Mo-Sa", "Tu-Su"
  const rangePattern=/([A-Z][a-z])-([A-Z][a-z])/g;
  let m;
  while((m=rangePattern.exec(oh))!==null){
    const from=dayOrder[m[1]],to=dayOrder[m[2]];
    if(from!==undefined&&to!==undefined){
      if(from<=to){if(targetNum>=from&&targetNum<=to)return true}
      else{if(targetNum>=from||targetNum<=to)return true} // wrap around (Fr-Mo)
    }
  }
  
  // Check "PH" (public holiday) — skip
  // Check if "off" or "closed" for this day
  const offPattern=new RegExp(targetDow+'[\\s:]*(?:off|closed)','i');
  if(offPattern.test(oh))return false;
  
  // If no day info found but has times, assume might be open
  return /\d{1,2}:\d{2}/.test(oh)?null:null;
}

function opensSoon(p){
  if(p.isOpen===true)return false; // already open
  const oh=p.opening_hours||'';
  if(!oh)return false;
  const berlinNow=getBerlinTime();
  const nowMin=berlinNow.getHours()*60+berlinNow.getMinutes();
  // Find opening times
  const times=[...oh.matchAll(/(\d{1,2}):(\d{2})/g)];
  for(const m of times){
    const openMin=parseInt(m[1])*60+parseInt(m[2]);
    if(openMin>nowMin&&openMin<=nowMin+180)return true; // opens within 3h
  }
  return false;
}

// ═══ QUICK FILTERS (Multi-Select, Client-Side) ═══
let activeFilters=new Set();

const FILTER_DEFS=[
  {icon:'🍺',label:'Kneipen',id:'pub',match:p=>/^(pub|irish-pub)$/i.test(p.category)||/kneipe|pub|bier/i.test(p.description||'')},
  {icon:'🍀',label:'Irish Pub',id:'irish',match:p=>/irish/i.test(p.category)||/irish|celtic|guinness|kilkenny|shamrock/i.test((p.description||'')+' '+(p.name||''))},
  {icon:'🍸',label:'Cocktails',id:'cocktail',match:p=>/cocktail/i.test(p.category)||/cocktail|mix|drink|martini|gin|highball/i.test((p.description||'')+' '+(p.name||'')+' '+(p.cuisine||''))},
  {icon:'🍷',label:'Wein',id:'wine',match:p=>/wine/i.test(p.category)||/wein|wine|vino|weinbar|vin\b|riesling|sommelier/i.test((p.description||'')+' '+(p.name||'')+' '+(p.cuisine||''))},
  {icon:'🪩',label:'Club',id:'club',match:p=>/nightclub|club|dance/i.test(p.category)||/club|dj|techno|party|disco|lounge/i.test((p.description||'')+' '+(p.name||''))},
  {icon:'☕',label:'Café',id:'cafe',match:p=>/cafe/i.test(p.category)},
  {icon:'🎵',label:'Live-Musik',id:'livemusic',match:p=>p.liveMusic===true||/live.?musik|jazz.?club|blues.?club|open.?mic/i.test((p.description||'')+' '+(p.name||''))},
  {icon:'🔥',label:'Beliebtheit',id:'sort_hot',match:null},
];

function renderQuickFilters(){
  const el=document.getElementById('quickSection');
  el.innerHTML=`
  <div class="section-head"><div class="section-title">Was suchst du?</div></div>
  <div class="quick-grid">${FILTER_DEFS.map(f=>`<button class="quick-btn${activeFilters.has(f.id)?' active':''}" onclick="toggleFilter('${f.id}')"><span class="qb-icon">${f.icon}</span><span class="qb-label">${f.label}</span></button>`).join('')}</div>`;
}

// ═══ VIBE HERO BUTTON ═══
function showVibeRecommendation(){
  if(!S.places||!S.places.length){alert('Daten werden geladen...');return;}
  
  // Get top vibe places that are open or opening soon
  let candidates=[...S.places].filter(p=>p.isOpen===true||opensToday(p)!==false);
  candidates.sort((a,b)=>(b.vibeScore||0)-(a.vibeScore||0));
  
  // Split: open NOW vs opens later
  const openNow=candidates.filter(p=>p.isOpen===true);
  const opensLater=candidates.filter(p=>p.isOpen!==true);
  
  // Top 3: prefer open places, fill with opening-soon
  const top=[...openNow.slice(0,3)];
  if(top.length<3) top.push(...opensLater.slice(0,3-top.length));
  
  if(!top.length){closeVibeOverlay();alert('Gerade hat leider nichts offen 😅');return;}
  
  const now=new Date();
  const timeStr=now.toLocaleTimeString('de-DE',{hour:'2-digit',minute:'2-digit',timeZone:'Europe/Berlin'});
  const dayStr=now.toLocaleDateString('de-DE',{weekday:'long',timeZone:'Europe/Berlin'});
  document.getElementById('vibeOverlayTime').textContent=`${dayStr}, ${timeStr} Uhr — basierend auf deinem Standort`;
  
  const list=document.getElementById('vibeRecoList');
  list.innerHTML='';
  
  const rankLabels=['🥇 #1 Empfehlung','🥈 #2 Alternative','🥉 #3 Option'];
  const reasons=[
    p=>{
      const parts=[];
      if(p.isOpen===true)parts.push('✅ Jetzt geöffnet');
      else parts.push('🕐 Öffnet heute noch');
      if(p.vibeScore>=70)parts.push('🔥 Hoher Vibe Score ('+p.vibeScore+')');
      else if(p.vibeScore>=50)parts.push('⚡ Guter Vibe ('+p.vibeScore+')');
      if(p.busynessLabel&&p.busynessLabel!=='Leer')parts.push('👥 '+p.busynessLabel);
      if(p.googleRating)parts.push('⭐ '+p.googleRating+' Google');
      if(p.distance)parts.push('📍 '+p.distance);
      if(p.description)parts.push(p.description.split('—')[0].trim());
      return parts.join(' · ');
    }
  ];
  
  top.forEach((p,i)=>{
    const card=document.createElement('div');
    card.className='vibe-reco'+(i===0?' top':'');
    
    const catMap={pub:'🍺 Pub',bar:'🍸 Bar',wine:'🍷 Weinbar',cocktailbar:'🍹 Cocktailbar',cafe:'☕ Café',restaurant:'🍽️ Restaurant',biergarten:'🌳 Biergarten'};
    const catLabel=catMap[p.category]||'📍 Location';
    
    const statsHtml=[];
    if(p.vibeScore)statsHtml.push(`<span class="vr-stat">Vibe ${p.vibeScore}</span>`);
    if(p.busyness!==undefined)statsHtml.push(`<span class="vr-stat" style="color:${p.busynessColor||'#aaa'}">${p.busynessLabel||'—'} ${p.busyness||0}%</span>`);
    if(p.googleRating)statsHtml.push(`<span class="vr-stat">⭐ ${p.googleRating}</span>`);
    if(p.distance)statsHtml.push(`<span class="vr-stat">📍 ${p.distance}</span>`);
    
    const reason=reasons[0](p);
    
    // Maps link
    const mapsUrl=`https://www.google.com/maps/dir/?api=1&destination=${p.lat},${p.lon}`;
    
    card.innerHTML=`
      <div class="vr-rank">${rankLabels[i]||'#'+(i+1)}</div>
      <div class="vr-name">${p.name}</div>
      <div class="vr-cat">${catLabel} · ${p.address||''}</div>
      <div class="vr-reason">${reason}</div>
      <div class="vr-stats">${statsHtml.join('')}</div>
      <div style="display:flex;gap:8px;margin-top:12px">
        <a class="vr-go" href="${mapsUrl}" target="_blank" style="flex:1">📍 Route</a>
        <a class="vr-go" href="https://www.google.com/maps/search/${encodeURIComponent((p.name||'')+' Hamburg')}" target="_blank" style="flex:1;background:linear-gradient(135deg,#FF9500,#FF6B35)">📌 Maps</a>
        ${p.website?`<a class="vr-go" href="${p.website}" target="_blank" style="flex:1;background:linear-gradient(135deg,#34C759,#30B050)">🌐 Web</a>`:''}
      </div>
    `;
    list.appendChild(card);
  });
  
  // Show overlay
  document.getElementById('vibeOverlay').classList.add('open');
  document.body.style.overflow='hidden';
}

function closeVibeOverlay(){
  document.getElementById('vibeOverlay').classList.remove('open');
  document.body.style.overflow='';
}

function toggleVibeHero(){
  showVibeRecommendation();
}

// ═══ METHODIK ═══
function toggleMethodik(){
  const body=document.getElementById('methodik-body');
  const toggle=document.querySelector('.methodik-toggle');
  const open=body.classList.toggle('open');
  toggle.setAttribute('aria-expanded',open);
}

function toggleFilter(cat){
  if(activeFilters.has(cat))activeFilters.delete(cat);
  else{
    activeFilters.add(cat);
    // Sort buttons are mutually exclusive
    if(cat==='sort_vibe')activeFilters.delete('sort_hot');
    if(cat==='sort_hot'){activeFilters.delete('sort_vibe');document.getElementById('vibeHeroBtn').classList.remove('active')}
  }
  // Sync vibe hero button state
  document.getElementById('vibeHeroBtn').classList.toggle('active',activeFilters.has('sort_vibe'));
  renderQuickFilters();
  renderTonightFeed();
}

// ═══ TONIGHT FEED ═══
function renderTonightFeed(){
  const el=document.getElementById('tonightSection');
  // Apply category filters (multi-select, client-side)
  let list=[...S.places];
  const catFilters=FILTER_DEFS.filter(f=>activeFilters.has(f.id)&&f.match);
  if(catFilters.length>0){
    list=list.filter(p=>catFilters.some(f=>f.match(p)));
  }

  // Sort: DEFAULT = Vibe (Leute treffen), toggle to Hot
  const sortByHot=activeFilters.has('sort_hot');
  list.sort((a,b)=>{
    const aOpen=a.isOpen!==false?1:0;const bOpen=b.isOpen!==false?1:0;
    if(aOpen!==bOpen)return bOpen-aOpen;
    if(sortByHot)return(b.hotScore||0)-(a.hotScore||0);
    // Default: Vibe first, then hot as tiebreaker
    const vDiff=(b.vibeScore||0)-(a.vibeScore||0);
    if(vDiff!==0)return vDiff;
    return(b.hotScore||0)-(a.hotScore||0);
  });

  // Filter based on selected day
  const sortByVibe=activeFilters.has('sort_vibe');
  let show;
  if(sortByVibe){
    // VIBE MODE: Zeige ALLE Bars sortiert nach Vibe — auch geschlossene
    // Damit sieht man wo heute Abend was geht, auch wenn gerade zu ist
    show=list.filter(p=>opensToday(p)!==false||p.isOpen===true).map(p=>{
      if(p.isOpen!==true) return {...p,_opensLater:true,_opensSoon:opensSoon(p)};
      return p;
    }).slice(0,40);
    // If still empty, show everything
    if(!show.length) show=list.slice(0,30).map(p=>({...p,_opensLater:true}));
  }else if(selectedDay===0){
    // Heute: offen + öffnet heute noch
    const open=list.filter(p=>p.isOpen===true);
    const opensLater=list.filter(p=>p.isOpen!==true&&opensToday(p)!==false);
    show=[
      ...open,
      ...opensLater.map(p=>({...p,_opensLater:true,_opensSoon:opensSoon(p)}))
    ].slice(0,30);
  }else{
    // Zukunft: zeig alles was an dem Tag öffnet (ignoriere aktuellen isOpen-Status)
    show=list.filter(p=>opensToday(p)!==false).map(p=>({...p,_opensLater:true})).slice(0,30);
  }

  // Fallback bei leeren Filterergebnissen
  if(!show.length && catFilters.length>0){
    const fallback=[...S.places].filter(p=>p.isOpen===true||opensSoon(p)).sort((a,b)=>(b.vibeScore||0)-(a.vibeScore||0)).slice(0,10);
    if(fallback.length){
      show=fallback;
      el.innerHTML=`<div style="padding:10px 0 4px;font-size:.78rem;color:var(--hot);font-weight:600">⚠️ Keine ${catFilters.map(f=>f.label||'').join('/')} gefunden — hier ist, was offen hat:</div>`;
    }
  }

  if(!show.length){
    el.innerHTML=`<div class="section-head"><div class="section-title">📍 In der Nähe</div></div>
    <div class="empty-msg">Gerade hat nichts auf — versuch einen größeren Radius oder anderen Tag</div>`;
    return;
  }

  const countOpen=show.filter(p=>p.isOpen===true).length;
  const vibeTitle=sortByVibe?`🎉 ${show.length} Spots nach Vibe — Wo triffst du Leute`:`📍 ${countOpen} offen in der Nähe`;
  el.innerHTML=`
  <div class="section-head">
    <div class="section-title">${vibeTitle}</div>
    <button class="section-more" onclick="switchTab('map')">Karte →</button>
  </div>
  ${show.map(p=>{
    const score=p.hotScore||0;const isOpen=p.isOpen!==false;const isHot=score>60;
    const iconBg=isHot?'background:rgba(255,107,53,.15)':isOpen?'background:rgba(52,199,89,.1)':'background:var(--surface2)';
    const isFav=isFavorite(p.name);
    return`<div class="tonight-card${isHot?' is-hot':''}" style="position:relative" onclick="openDetail(findPlace('${esc(p.name)}'))">
      <span class="fav-btn" onclick="event.stopPropagation();toggleFavorite('${esc(p.name)}')" style="top:12px;right:12px">${isFav?'❤️':'🤍'}</span>
      <div class="tc-top">
        <div class="tc-icon" style="${iconBg}">${getCatIcon(p.category)}</div>
        <div class="tc-info">
          <div class="tc-name">${esc(p.name)}</div>
          <div class="tc-sub">
            <span>${getCatName(p.category)}</span>
            <span>·</span>
            <span>${p.distance?Math.round(p.distance)+'m':p._dist?Math.round(p._dist)+'m':''}</span>
          </div>
        </div>
        <div style="text-align:right">
          ${(p.vibeScore||0)>0?`<div style="font-size:.9rem;font-weight:800;color:#BB86FC">${p.vibeEmoji||'👀'} ${p.vibeScore}%</div>`:''}
          ${score>20?`<div style="font-size:.65rem;color:var(--hot);font-weight:600">🔥${score}%</div>`:''}
        </div>
      </div>
      <div class="tc-tags">
        ${isOpen?'<span class="tc-tag open">Offen</span>':p._opensSoon?'<span class="tc-tag" style="background:rgba(255,149,0,.12);color:#FF9500">⏰ Öffnet bald</span>':p._opensLater?'<span class="tc-tag" style="background:rgba(255,255,255,.08);color:var(--text2)">📅 Öffnet heute</span>':'<span class="tc-tag" style="background:rgba(255,255,255,.06);color:var(--text3)">Zeiten unbekannt</span>'}
        ${p.googleRating?`<span class="tc-tag" style="background:rgba(255,193,7,.12);color:#FFC107">⭐ ${p.googleRating}</span>`:''}
        ${p.smoker?'<span class="tc-tag" style="background:rgba(255,255,255,.06);color:#aaa" title="Raucherbar">🚬</span>':''}
        ${p.estimatedBusyness>10&&p.isOpen!==false?`<span class="tc-tag" style="background:${busynessBg(p.busynessColor)};color:${p.busynessColor}" title="📊 Geschätzte Auslastung">${busynessIcon(p.estimatedBusyness)} ${p.busynessLabel||''}</span>`:''}
        ${(p.vibeScore||0)>=55?'<span class="tc-tag" style="background:rgba(187,134,252,.12);color:#BB86FC">Leute treffen</span>':''}
        ${isHot?'<span class="tc-tag hot">Hot</span>':''}
        ${p.liveMusic?'<span class="tc-tag event">🎵 Live</span>':''}
        ${p.has_events?'<span class="tc-tag event">🎉 Event</span>':''}
      </div>
    </div>`;
  }).join('')}`;
}

// ═══ EVENTS TAB ═══
const VIBES=[
  {id:'ai_tech',label:'🤖 AI & Tech',kw:/\bai\b|artificial|intelligence|agents?|llm|machine learning|deep.?tech|quantum|robotics|tech/i},
  {id:'startup',label:'🚀 Startups',kw:/startup|gründer|founder|venture|pitch|incubat|accelerat/i},
  {id:'business',label:'💼 Business',kw:/business|entrepreneur|c-level|leadership|strateg|management|executive/i},
  {id:'networking',label:'🤝 Networking',kw:/networking|ecosystem|community|meetup|connect|austausch|after.?work/i},
];
let activeVibes=new Set();

function initVibeFilters(){
  const el=document.getElementById('vibeFilters');
  el.innerHTML=VIBES.map(v=>`<button class="loc-btn${activeVibes.has(v.id)?' active':''}" onclick="toggleVibe('${v.id}')">${v.label}</button>`).join('');
}
function toggleVibe(id){
  if(activeVibes.has(id))activeVibes.delete(id);else activeVibes.add(id);
  initVibeFilters();loadNetworkEvents();
}

let activeEventTime='week';
function setEventTime(t){
  activeEventTime=t;
  document.querySelectorAll('#eventTimeFilter .loc-btn').forEach(b=>{
    b.classList.toggle('active',b.textContent.trim()==={all:'Alle',today:'Heute',tomorrow:'Morgen',week:'Diese Woche',later:'Später'}[t]);
  });
  loadNetworkEvents();
}

function eventDateFilter(dateStr){
  if(!dateStr||dateStr==='TBD')return activeEventTime==='all'||activeEventTime==='later';
  const d=new Date(dateStr);const now=new Date();
  const today=new Date(now.getFullYear(),now.getMonth(),now.getDate());
  const tomorrow=new Date(today);tomorrow.setDate(today.getDate()+1);
  const dayAfterTomorrow=new Date(today);dayAfterTomorrow.setDate(today.getDate()+2);
  const endOfWeek=new Date(today);endOfWeek.setDate(today.getDate()+(7-today.getDay()));
  
  if(activeEventTime==='today')return d>=today&&d<tomorrow;
  if(activeEventTime==='tomorrow')return d>=tomorrow&&d<dayAfterTomorrow;
  if(activeEventTime==='week')return d>=today&&d<=endOfWeek;
  if(activeEventTime==='later')return d>endOfWeek;
  return true; // 'all'
}

async function loadNetworkEvents(){
  const el=document.getElementById('eventsFeed');
  el.innerHTML='<div class="skeleton"></div><div class="skeleton"></div>';
  const d=await api('/api/network-events');
  if(!d||!d.events||!d.events.length){el.innerHTML='<div class="empty-msg">Keine Events gefunden</div>';return}

  let events=d.events.map(e=>{
    let score=e.eventQuality||30;
    const all=((e.title||'')+(e.description||'')+(e.tags||[]).join(' ')+(e.location||'')).toLowerCase();

    let matched=[];
    if(activeVibes.size>0){
      let hit=false;
      VIBES.forEach(v=>{if(activeVibes.has(v.id)&&v.kw.test(all)){score+=20;hit=true;matched.push(v.label)}});
      if(!hit)score-=10;
    }else{
      VIBES.forEach(v=>{if(v.kw.test(all)){score+=5;matched.push(v.label)}});
    }
    const att=parseInt(e.attendees)||0;
    if(att>100)score+=12;else if(att>50)score+=8;else if(att>20)score+=4;
    return{...e,_score:Math.max(0,Math.min(100,score)),_vibes:matched.slice(0,3)};
  }).filter(Boolean).sort((a,b)=>b._score-a._score);

  // Apply time filter
  events=events.filter(e=>eventDateFilter(e.date));

  if(!events.length){
    el.innerHTML=`<div class="empty-msg">Keine Events für diesen Zeitraum</div>`;
    return;
  }

  // Group by category, then by date within each group
  const catOrder=['networking','startup','social','conference','workshop','culture','community','other'];
  const catLabels={networking:'🤝 Networking & Meetups',startup:'🚀 Startup Events',social:'🎉 Social Events',conference:'📋 Konferenzen',workshop:'🛠 Workshops',culture:'🎭 Kultur',community:'🏘 Community',other:'📌 Weitere Events'};
  const byCat={};
  events.forEach(e=>{const c=e.eventCategory||'other';if(!byCat[c])byCat[c]=[];byCat[c].push(e)});

  let html='';
  catOrder.forEach(cat=>{
    if(!byCat[cat]||!byCat[cat].length)return;
    html+=`<div style="font-size:.9rem;font-weight:800;color:var(--text);margin:18px 0 8px;padding:6px 0;border-bottom:1px solid var(--border)">${catLabels[cat]||cat}</div>`;
    // Group by date within category
    const grouped={};
    byCat[cat].forEach(e=>{const dt=e.date||'TBD';if(!grouped[dt])grouped[dt]=[];grouped[dt].push(e)});
    Object.keys(grouped).sort().forEach(date=>{
      const label=formatDate(date);
      html+=`<div style="font-size:.78rem;font-weight:600;color:var(--text2);margin:10px 0 6px">${label}</div>`;
      grouped[date].forEach(e=>{
        const high=e._score>=60;
        const qBadge=e._score>70?'🟢':e._score>=40?'🟡':'';
        const openBadge=e.isOpenAccess?'<span class="tc-tag" style="background:rgba(52,199,89,.15);color:#34C759;font-weight:600">🔓 Offen</span>':'';
        const potBg=high?'background:linear-gradient(135deg,#FF3B30,#FF6B35);color:#fff':e._score>=35?'background:var(--surface2);color:var(--hot)':'background:var(--surface2);color:var(--text2)';
        const timeStr=e.time?(e.end_time?`${e.time} – ${e.end_time}`:e.time+' Uhr'):'';
        html+=`<div class="ev-feed-card${high?' high-potential':''}"${e.url&&e.url!=='https://lu.ma/hamburg'?` onclick="window.open('${esc(e.url)}','_blank')"`:''}> 
          ${timeStr?`<div class="efc-time">${timeStr}</div>`:''}
          <div class="efc-title">${qBadge?qBadge+' ':''}${esc(e.title)}</div>
          ${e.location?`<div class="efc-location">📍 ${esc(e.location)}</div>`:''}
          <div class="efc-bottom">
            <div class="efc-tags">${openBadge}${e.source&&(e.source==='szene-hamburg'||e.source==='hamburg.de')?`<span class="tc-tag" style="background:rgba(255,149,0,.12);color:#FF9500">📰 ${esc(e.source)}</span>`:''} ${(e._vibes||[]).map(v=>`<span class="tc-tag" style="background:rgba(10,132,255,.1);color:var(--blue)">${v}</span>`).join('')}${e.organizer?`<span class="tc-tag">👤 ${esc(e.organizer)}</span>`:''}</div>
            <div class="efc-potential" style="${potBg}">${e._score}%</div>
          </div>
        </div>`;
      });
    });
  });
  el.innerHTML=html||'<div class="empty-msg">Keine passenden Events</div>';
}

function formatDate(s){
  if(!s||s==='TBD')return'📅 Termine folgen';
  try{
    const d=new Date(s);const t=new Date();const tom=new Date(t);tom.setDate(t.getDate()+1);
    if(d.toDateString()===t.toDateString())return'📅 Heute';
    if(d.toDateString()===tom.toDateString())return'📅 Morgen';
    return'📅 '+d.toLocaleDateString('de-DE',{weekday:'long',month:'short',day:'numeric'});
  }catch{return'📅 '+s}
}

// ═══ MAP ═══
function initMap(){
  if(mapInited)return;
  map=L.map('map',{zoomControl:false,attributionControl:false}).setView([S.lat,S.lon],15);
  L.tileLayer('https://{s}.basemaps.cartocdn.com/dark_all/{z}/{x}/{y}{r}.png',{maxZoom:19}).addTo(map);
  startMarker=L.marker([S.lat,S.lon],{draggable:true,icon:L.divIcon({className:'',html:'<div style="width:18px;height:18px;background:#0A84FF;border:3px solid #fff;border-radius:50%;box-shadow:0 2px 8px rgba(0,0,0,.5)"></div>',iconSize:[18,18],iconAnchor:[9,9]})}).addTo(map);
  startMarker.on('dragend',e=>{const p=e.target.getLatLng();S.lat=p.lat;S.lon=p.lng;loadAll()});
  radiusCircle=L.circle([S.lat,S.lon],{radius:S.radius,color:'#0A84FF',fillColor:'#0A84FF',fillOpacity:.06,weight:1.5}).addTo(map);

  // Map chips
  const cats=[{l:'Alle',v:''},{l:'🍺 Kneipen',v:'pub'},{l:'🍸 Cocktail',v:'cocktail'},{l:'🍷 Wein',v:'wine'},{l:'🪩 Clubs',v:'club'}];
  document.getElementById('mapChips').innerHTML=cats.map(c=>`<button class="map-chip${!c.v?' active':''}" onclick="mapFilter('${c.v}')">${c.l}</button>`).join('');

  mapInited=true;
  updateMap();
  initSheetDrag();
}

function mapFilter(cat){
  S.category=cat;
  document.querySelectorAll('.map-chip').forEach(c=>c.classList.toggle('active',c.textContent.includes(cat?getCatName(cat):'Alle')));
  loadAll();
}

function updateMap(){
  if(!map)return;
  map.setView([S.lat,S.lon],S.radius>5000?12:15);
  startMarker.setLatLng([S.lat,S.lon]);
  radiusCircle.setLatLng([S.lat,S.lon]).setRadius(S.radius);
  S.markers.forEach(m=>map.removeLayer(m));S.markers=[];
  S.places.forEach(p=>{
    const isHot=p.hotScore&&p.hotScore>70;const isOpen=p.isOpen!==false;
    const color=isHot?'#FF6B35':isOpen?'#34C759':'#FF453A';const sz=isHot?16:12;
    const mk=L.marker([p.lat,p.lon],{icon:L.divIcon({className:'',html:`<div style="width:${sz+6}px;height:${sz+6}px;background:${color};border:2px solid rgba(255,255,255,.6);border-radius:50%;box-shadow:0 1px 6px rgba(0,0,0,.4);display:flex;align-items:center;justify-content:center;font-size:${sz-4}px">${getCatIcon(p.category)}</div>`,iconSize:[sz+6,sz+6],iconAnchor:[(sz+6)/2,(sz+6)/2]})}).addTo(map);
    mk.on('click',()=>openDetail(p));S.markers.push(mk);
  });

  // Sheet list
  const scroll=document.getElementById('mapSheetScroll');
  const open=S.places.filter(p=>p.isOpen!==false).sort((a,b)=>(b.hotScore||0)-(a.hotScore||0)).slice(0,15);
  scroll.innerHTML=open.map(p=>{
    const score=p.hotScore||0;
    return`<div class="tonight-card" style="margin-bottom:8px" onclick="openDetail(findPlace('${esc(p.name)}'))">
      <div class="tc-top">
        <div class="tc-icon" style="background:rgba(255,107,53,.15)">${getCatIcon(p.category)}</div>
        <div class="tc-info"><div class="tc-name">${esc(p.name)}</div><div class="tc-sub"><span>${getCatName(p.category)}</span></div></div>
        ${score>0?`<div class="tc-score">🔥${score}</div>`:''}
      </div>
    </div>`;
  }).join('');
}

// ═══ SHEET DRAG ═══
function initSheetDrag(){
  const sheet=document.getElementById('mapSheet');
  const handle=document.getElementById('sheetHandle');
  let states=['min','mid','full'],si=0,startY,startT,dy;
  function snap(idx){si=Math.max(0,Math.min(2,idx));sheet.className='map-sheet'+(si===1?' mid':si===2?' full':'');sheet.style.transform=''}
  handle.addEventListener('touchstart',e=>{startY=e.touches[0].clientY;startT=Date.now();sheet.classList.add('dragging');dy=0},{passive:true});
  handle.addEventListener('touchmove',e=>{dy=e.touches[0].clientY-startY;const cur=si===0?window.innerHeight-160-64:si===1?window.innerHeight*0.45-64:0;sheet.style.transform=`translateY(${Math.max(0,cur+dy)}px)`},{passive:true});
  handle.addEventListener('touchend',()=>{sheet.classList.remove('dragging');const fast=Date.now()-startT<250;if(fast&&dy<-30)snap(Math.min(2,si+1));else if(fast&&dy>30)snap(Math.max(0,si-1));else if(dy<-80)snap(Math.min(2,si+1));else if(dy>80)snap(Math.max(0,si-1));else snap(si)});
}

// ═══ DETAIL ═══
function findPlace(name){return S.places.find(x=>x.name===name)||S.hot.find(x=>x.name===name)||null}

async function openDetail(p){
  if(!p)return;
  const ds=document.getElementById('detailSheet');const sc=document.getElementById('detailScroll');
  let peakHtml='',weekHtml='';
  try{
    const hs=await api(`/api/hotscore?name=${encodeURIComponent(p.name)}`);
    if(hs&&hs.peak){
      const pk=hs.peak;
      const dayNames={So:'Sonntag',Mo:'Montag',Di:'Dienstag',Mi:'Mittwoch',Do:'Donnerstag',Fr:'Freitag',Sa:'Samstag'};
      if(pk.today&&pk.today.open!==null){
        peakHtml=`<div style="background:linear-gradient(135deg,#FF6B35,#FF9500);border-radius:14px;padding:14px 16px;color:#fff;margin-bottom:16px">
          <div style="font-size:.75rem;font-weight:600;opacity:.85;margin-bottom:4px">🔥 Beste Zeit (${dayNames[pk.today.day]||pk.today.day})</div>
          <div style="font-size:1.3rem;font-weight:800">${pk.today.label}</div>
        </div>`;
      }
      if(pk.todayHeatmap&&pk.todayHeatmap.length){
        peakHtml+=`<div class="det-section"><h3>Belebtheit heute</h3><div class="peak-bar-wrap"><div class="peak-bar">`;
        pk.todayHeatmap.forEach(h=>{
          const c=h.intensity>75?'#FF3B30':h.intensity>50?'#FF6B35':h.intensity>25?'#FFD60A':'rgba(255,255,255,.08)';
          peakHtml+=`<div class="pb-cell" style="background:${c};height:${Math.max(4,h.intensity*0.28)}px"></div>`;
        });
        peakHtml+=`</div><div class="peak-hours-labels">`;
        pk.todayHeatmap.forEach((h,i)=>{if(i%2===0)peakHtml+=`<div class="phl">${String(h.hour).padStart(2,'0')}</div>`;else peakHtml+=`<div class="phl"></div>`});
        peakHtml+=`</div></div></div>`;
      }
      if(pk.weekly&&pk.weekly.length){
        const berlinDow=['Sun','Mon','Tue','Wed','Thu','Fri','Sat'].indexOf(new Intl.DateTimeFormat('en-US',{timeZone:'Europe/Berlin',weekday:'short'}).format(new Date()));
        weekHtml=`<div class="det-section"><h3>Wochenübersicht</h3><div class="week-cal">`;
        pk.weekly.forEach(w=>{
          const isToday=w.dow===berlinDow;
          weekHtml+=`<div class="wc-row${isToday?' today':''}"><div class="wc-day">${w.day}</div><div class="wc-icon">${w.open===null?'🔴':'🟡'}</div><div class="wc-time">${w.open===null?'geschlossen':w.label}</div>${isToday?'<div style="font-size:.7rem;color:var(--hot);font-weight:700">HEUTE</div>':''}</div>`;
        });
        weekHtml+=`</div></div>`;
      }
    }
  }catch(e){}

  const score=p.hotScore||0;const ringColor=score>70?'#FF3B30':score>40?'#FF9500':'#48484A';
  const detFav=isFavorite(p.name);
  sc.innerHTML=`
  <div style="display:flex;justify-content:space-between;align-items:flex-start">
    <div class="det-name" style="flex:1">${esc(p.name)}</div>
    <span style="font-size:1.5rem;cursor:pointer;padding:4px 8px" onclick="toggleFavorite('${esc(p.name)}');openDetail(findPlace('${esc(p.name)}'))">${detFav?'❤️':'🤍'}</span>
  </div>
  <div class="det-addr">${esc(p.address||p.street||'')}</div>
  <div style="display:flex;justify-content:center;gap:20px;margin-bottom:16px">
    <div class="det-score-ring" style="background:${ringColor}20;color:${ringColor}"><span class="ring-emoji">🔥</span><span class="ring-val">${score}%</span></div>
    <div class="det-score-ring" style="background:rgba(187,134,252,.15);color:#BB86FC"><span class="ring-emoji">${p.vibeEmoji||'👀'}</span><span class="ring-val">${p.vibeScore||0}%</span></div>
  </div>
  <div style="display:flex;justify-content:center;gap:24px;margin-bottom:16px;font-size:.72rem;color:var(--text2)">
    <span>Beliebtheit</span><span>Vibe & Action</span>
  </div>
  <div class="det-actions">
    <a class="da-route" href="https://www.google.com/maps/dir/?api=1&destination=${p.lat},${p.lon}" target="_blank">📍 Route</a>
    <a class="da-search" href="https://www.google.com/maps/search/${encodeURIComponent((p.name||'')+' Hamburg')}" target="_blank">📌 Maps</a>
    ${p.website?`<a class="da-web" href="${esc(p.website)}" target="_blank">🌐 Web</a>`:`<a class="da-web" href="https://www.google.com/search?q=${encodeURIComponent((p.name||'')+' Hamburg')}" target="_blank">🔍 Google</a>`}
  </div>
  ${peakHtml}
  <div style="display:flex;flex-wrap:wrap;gap:8px;margin-bottom:16px">
    ${p.category?`<span class="badge" style="background:rgba(10,132,255,.12);color:var(--blue)">${getCatIcon(p.category)} ${getCatName(p.category)}</span>`:''}
    ${p.isOpen!==false?'<span class="badge" style="background:rgba(52,199,89,.12);color:var(--open)">🟢 Geöffnet</span>':'<span class="badge" style="background:rgba(255,69,58,.12);color:var(--closed)">🔴 Geschlossen</span>'}
    ${p.liveMusic?'<span class="badge" style="background:rgba(123,31,162,.12);color:#BB86FC">🎵 Live-Musik</span>':''}
  </div>
  ${p.opening_hours||p.openingHours?`<div class="det-section"><h3>Öffnungszeiten</h3><div style="font-size:.85rem;color:var(--text2);white-space:pre-line">${esc(p.opening_hours||p.openingHours||'')}</div></div>`:''}
  ${weekHtml}
  `;
  ds.classList.add('open');
}
document.getElementById('detailClose').onclick=()=>document.getElementById('detailSheet').classList.remove('open');

// ═══ SEARCH ═══
document.getElementById('searchInput').addEventListener('input',e=>{
  const q=e.target.value.toLowerCase();
  document.querySelectorAll('#mapSheetScroll .tonight-card').forEach(c=>{c.style.display=c.textContent.toLowerCase().includes(q)?'':'none'});
});

// ═══ TAB NAVIGATION ═══
function switchTab(tab){
  currentTab=tab;
  document.querySelectorAll('.nav-btn').forEach(b=>b.classList.toggle('active',b.dataset.tab===tab));

  // Hide all
  document.getElementById('feedHeute').classList.remove('active');
  document.getElementById('mapTab').classList.remove('active');
  document.getElementById('feedEvents').classList.remove('active');
  document.getElementById('feedSources').classList.remove('active');
  document.getElementById('mapSearch').style.display='none';
  document.getElementById('mapChips').style.display='none';
  document.getElementById('mapSheet').style.display='none';

  if(tab==='heute'){
    document.getElementById('feedHeute').classList.add('active');
  }else if(tab==='map'){
    document.getElementById('mapTab').classList.add('active');
    document.getElementById('mapSearch').style.display='block';
    document.getElementById('mapChips').style.display='flex';
    document.getElementById('mapSheet').style.display='flex';
    initMap();
    setTimeout(()=>map&&map.invalidateSize(),100);
  }else if(tab==='events'){
    document.getElementById('feedEvents').classList.add('active');
    initVibeFilters();
    loadNetworkEvents();
  }else if(tab==='sources'){
    document.getElementById('feedSources').classList.add('active');
    loadSources();
  }
}

document.querySelectorAll('.nav-btn').forEach(b=>b.onclick=()=>switchTab(b.dataset.tab));

// ═══ SOURCES TAB ═══
async function loadSources(){
  const el=document.getElementById('sourcesList');
  el.innerHTML='<div class="skeleton"></div>';
  try{
    const data=await api('/api/sources');
    if(!data||!data.sources){el.innerHTML='<p style="color:var(--text2)">Keine Daten</p>';return}
    el.innerHTML=data.sources.map(s=>{
      const statusColor=s.status==='ok'?'#34C759':s.status==='partial'?'#FF9500':'#FF453A';
      const statusIcon=s.status==='ok'?'✅':s.status==='partial'?'⚠️':'❌';
      const ago=s.lastRun?timeAgo(s.lastRun):'Nie';
      return `<div style="background:var(--surface);border-radius:16px;padding:16px">
        <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:8px">
          <div style="font-weight:700;font-size:1rem">${s.icon||'📊'} ${s.name}</div>
          <div style="font-size:.8rem;color:${statusColor};font-weight:600">${statusIcon} ${s.statusText||s.status}</div>
        </div>
        <div style="font-size:.82rem;color:var(--text2);margin-bottom:6px">${s.description||''}</div>
        <div style="display:flex;gap:16px;font-size:.75rem;color:var(--text3)">
          <span>📦 ${s.count||0} Einträge</span>
          <span>🕐 ${ago}</span>
          <span style="color:${statusColor}">●  Prio ${s.priority||'—'}</span>
        </div>
        ${s.error?`<div style="font-size:.75rem;color:#FF453A;margin-top:6px">⚠️ ${s.error}</div>`:''}
      </div>`;
    }).join('');
  }catch(e){el.innerHTML='<p style="color:#FF453A">Fehler beim Laden</p>'}
}
function timeAgo(ts){
  const d=Date.now()-new Date(ts).getTime();
  if(d<60000)return 'gerade eben';
  if(d<3600000)return Math.floor(d/60000)+'m';
  if(d<86400000)return Math.floor(d/3600000)+'h';
  return Math.floor(d/86400000)+'d';
}

// ═══ WEATHER & EVENTS BANNER ═══
async function loadWeatherBanner(){
  try{
    const d=await api('/api/weather');
    if(!d)return;
    const wb=document.getElementById('weatherBanner');
    if(d.weather){
      wb.style.display='flex';
      wb.innerHTML=`<span style="font-size:1.2rem">${d.weatherEmoji||'🌡️'}</span><span>${d.weatherText||''}</span>`;
    }
    const eb=document.getElementById('eventBanner');
    if(d.majorEvents&&d.majorEvents.length>0){
      eb.style.display='flex';
      eb.innerHTML=`<span style="font-size:1.2rem">🎉</span><span>${d.majorEvents.map(e=>e.name).join(' & ')} — Heute ist Hamburg voll!</span>`;
    }else{eb.style.display='none'}
  }catch(e){}
}

// ═══ INIT ═══
updateGreeting();
loadWeatherBanner();
// Try GPS first, fallback to Zuhause
if(navigator.geolocation){
  navigator.geolocation.getCurrentPosition(pos=>{
    S.lat=pos.coords.latitude;S.lon=pos.coords.longitude;S.currentLoc='gps';
    // Smart radius: match saved location if nearby, else urban/rural detection
    const gLat=pos.coords.latitude, gLon=pos.coords.longitude;
    const nearSaved=Object.values(SAVED_LOCS).find(s=>{const d=Math.sqrt((gLat-s.lat)**2+(gLon-s.lon)**2)*111000;return d<s.radius});
    S.radius = nearSaved ? nearSaved.radius : ((gLat>53.4&&gLat<53.7&&gLon>9.7&&gLon<10.2) ? 3000 : 20000);
    document.querySelectorAll('.loc-btn').forEach(b=>b.classList.toggle('active',b.dataset.loc==='gps'));
    loadAll();
  },()=>{loadAll()},{enableHighAccuracy:true,timeout:5000});
}else{loadAll()}
</script>
</body>
</html>
